generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum ChallengeStatus {
  PENDING
  ACCEPTED
  COMPLETED
  CANCELED
}

enum MatchType {
  CHALLENGE
  LEAGUE
  FRIENDLY
}

model Player {
  id        String    @id @default(uuid())
  name      String
  phone     String?
  birthDate DateTime?

  active       Boolean @default(true)
  participates Boolean @default(true) // ✅ participa do ranking do ano
  currentRank  Int?    @unique // ✅ pode ser NULL (sem ranking)

  createdAt DateTime @default(now())

  challengerChallenges Challenge[] @relation("challenger")
  challengedChallenges Challenge[] @relation("challenged")

  matchesP1 Match[] @relation("p1")
  matchesP2 Match[] @relation("p2")
  wins      Match[] @relation("winner")

  rankHistory RankHistory[]
}

model Challenge {
  id           String          @id @default(uuid())
  challengerId String
  challengedId String
  status       ChallengeStatus @default(PENDING)
  expiresAt    DateTime
  createdAt    DateTime        @default(now())

  challenger Player @relation("challenger", fields: [challengerId], references: [id])
  challenged Player @relation("challenged", fields: [challengedId], references: [id])

  // ✅ 1 challenge -> 1 match (quando finaliza)
  match Match?
}

model Match {
  id          String    @id @default(uuid())
  type        MatchType
  challengeId String?   @unique

  player1Id String
  player2Id String
  winnerId  String

  sets1 Int
  sets2 Int
  wo    Boolean @default(false)

  playedAt  DateTime @default(now())
  createdAt DateTime @default(now())

  challenge Challenge? @relation(fields: [challengeId], references: [id])
  player1   Player     @relation("p1", fields: [player1Id], references: [id])
  player2   Player     @relation("p2", fields: [player2Id], references: [id])
  winner    Player     @relation("winner", fields: [winnerId], references: [id])

  rankHistory RankHistory[]
}

model RankHistory {
  id         String   @id @default(uuid())
  matchId    String
  playerId   String
  rankBefore Int
  rankAfter  Int
  createdAt  DateTime @default(now())

  match  Match  @relation(fields: [matchId], references: [id])
  player Player @relation(fields: [playerId], references: [id])

  @@index([playerId, createdAt])
  @@index([matchId])
}
