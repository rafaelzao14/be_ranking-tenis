NODE_ENV=development
PORT=3333
CORS_ORIGIN=http://localhost:4200

# App database URL used by TypeORM
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ranking_tenis?schema=public"

# Optional split DB vars (can be used by scripts/tools)
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=ranking_tenis
DB_SSL=false

JWT_SECRET=change-me
JWT_REFRESH_SECRET=change-me-too

# Auth login para /auth/login (cookie httpOnly)
AUTH_USER=admin
AUTH_PASSWORD=admin123
AUTH_TOKEN_EXPIRES_IN_SECONDS=43200
